# .env.example — Root-level env for docker-compose
# Copy to .env and fill in real values

# Database
DB_PASSWORD=change_me_strong_password

# JWT (generate: node -e "require('crypto').randomBytes(64).toString('hex')")
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING_64_CHARS_MIN

# Groq AI chat (free at https://console.groq.com)
GROQ_API_KEY=your_groq_key_here

# Frontend URL (for CORS whitelist)
FRONTEND_URL=https://your-domain.com

# Vite build arg (public URL of backend)
VITE_API_URL=https://your-backend-domain.com
