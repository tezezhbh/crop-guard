# backend/.env.example — CropGuard AI
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env to git — it is excluded by .gitignore.
#
# ── JWT Secret ───────────────────────────────────────────────────────────────
# Must be at least 32 random characters.
# Generate one: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_STRONG_64_CHAR_RANDOM_SECRET

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:YOUR_DB_PASSWORD@localhost:5432/crop_db

# ── ML / AI Server ───────────────────────────────────────────────────────────
AI_SERVER_URL=http://localhost:8000

# ── AI API Keys ──────────────────────────────────────────────────────────────
# Anthropic (chat assistant) — https://console.anthropic.com
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_KEY

# Groq (alternative AI backend) — https://console.groq.com/keys
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_KEY

# ── Payment webhook (optional) ───────────────────────────────────────────────
# If you integrate a payment gateway (Stripe/Chapa), set this to a strong
# random secret and configure your webhook to send it in the
# x-upgrade-webhook-secret header. Leave unset in dev (set ALLOW_DIRECT_UPGRADE=true).
UPGRADE_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET

# Development only — allows /api/auth/upgrade without webhook auth.
# Set to false or remove in production.
ALLOW_DIRECT_UPGRADE=true
